# Banco de dados: SQLite (arquivo).
# - Execução local (sem Docker): caminho relativo ao projeto.
# - No Docker: o docker-compose sobrescreve com sqlite:////data/dados.db
#   (volume persistente). Não precisa mexer aqui para o container.
DATABASE_URL=sqlite:///./dados.db

SECRET_KEY=mude-esta-chave-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Origens permitidas no CORS (separadas por vírgula). Em produção use o domínio real.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
